rules_version = '2';

// Firestore security rules for SteigerDojoEsports.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }
    function isStaff() {
      return isSignedIn() && userRole() in ['admin', 'organizer'];
    }
    // Privileged (staff) roles. Users may not grant these to themselves.
    function isStaffRole(role) {
      return role in ['admin', 'organizer'];
    }

    // Users: public read, self-write.
    // A user may edit their own profile, but may only change `role` among the
    // non-privileged roles (player <-> captain — e.g. when creating a team or
    // leaving one). Promotion to a staff role (admin/organizer) is admin-only.
    match /users/{uid} {
      allow read: if true;
      allow create: if isSelf(uid);
      allow update: if isAdmin()
        || (isSelf(uid)
            && (!('role' in request.resource.data)
                || request.resource.data.role == resource.data.role
                || (!isStaffRole(request.resource.data.role) && !isStaffRole(resource.data.role))));
      allow delete: if isAdmin();
    }

    // Teams: public read; captain or staff can write.
    match /teams/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // captaincy checks enforced client-side + functions
      allow delete: if isSignedIn() &&
        (resource.data.captainId == request.auth.uid || isStaff());
    }

    match /teamInvites/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // Tournaments: public read (drafts filtered client-side); staff write.
    match /tournaments/{id} {
      allow read: if true;
      allow create: if isStaff();
      allow update, delete: if isStaff()
        || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /registrations/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /matches/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /brackets/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /matchMessages/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStaff();
    }

    match /news/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /sponsors/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Notifications: a user reads their own; anyone signed in may create
    // (e.g. team invites). Staff can broadcast.
    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
