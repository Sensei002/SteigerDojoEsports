# Firebase configuration — copy this file to `.env` and fill in your project values.
# Find these in Firebase Console > Project settings > General > Your apps > SDK setup.
# All client-side Vite env vars MUST be prefixed with VITE_.

VITE_FIREBASE_API_KEY=AIzaSyBSHoQfGF99ItNVFymfpHt6z-WmuzTosR4
VITE_FIREBASE_AUTH_DOMAIN=steigerdojoesports.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=steigerdojoesports
VITE_FIREBASE_STORAGE_BUCKET=steigerdojoesports.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=395475824618
VITE_FIREBASE_APP_ID=1:395475824618:web:f05ddf3e5a07d421480c93
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Note: VITE_FIREBASE_STORAGE_BUCKET is no longer used (Storage replaced by Cloudinary)
# but is harmless to leave set.

# Realtime Database URL — required so tournament registrations mirror into Match
# Control. Create the database in Firebase Console > Build > Realtime Database,
# then paste the exact URL it shows (region may differ from the default below).
VITE_FIREBASE_DATABASE_URL=https://steigerdojoesports-default-rtdb.asia-southeast1.firebasedatabase.app

# Cloudinary — free image uploads (replaces the now-paid Firebase Storage).
# Create a free account at https://cloudinary.com, then:
#   Cloud name: Dashboard.
#   Upload preset: Settings > Upload > Upload presets > Add (Signing Mode: Unsigned).
VITE_CLOUDINARY_CLOUD_NAME=dw5u2ezhn
VITE_CLOUDINARY_UPLOAD_PRESET=steigerdojoesports
